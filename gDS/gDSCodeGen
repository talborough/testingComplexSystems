# This starts by scanning the input file over and over again (in "passes"), looking for invalid syntax and semantics.
# By the time the passes are done the input file has been "validated" and the code generators can work with impunity.
#

#
# Data definition syntax we verify (see website for more detail):
#
#   defineTable   TableName
#       Table names must not contain underscores.
#
#   defineColumn  TableName_ColumnName  [optional initial value]
#       One underscore: table_column. Optional initial value.
#
#   defineColumn  TableName_OtherTable_Ref  [optional initial value]
#       Two underscores, ends with "_Ref": foreign key reference.
#
#   defineIndex   TableName_ColumnName2Ref
#       One underscore, ends with "2Ref": index naming.
#
#   endTable
#
#   defineUnary   Name  <required initial value>
#
#   defineList    ListName
#   defineDict    DictName
#

import os
import sys
import inspect

LinesToProcess = []  # The input file text, line by line
GeneratedCode = ""  # The output file contents
AllTableNames = []  # All the tables names from the first pass - used as needed later


def codeLine():
    """Return the caller's line number as a string for debug output, or '' if disabled."""
    return ""
    # return (f"{inspect.currentframe().f_back.f_lineno}: ")


#
# The code below processes the ".dd" files in multiple passes. The goal here is that each pass completes a simple
# check of the ".dd" file's syntax or semantics or, generates a specific chunk of code.
#


def getNextLineToProcess(lineIndex):
    """
    Scan from lineIndex and return the next non-empty, non-comment line.

    Strips comments (from # onward), then splits each line into at most
    three fields:
      1) primary keyword
      2) element name
      3) initial value (kept as the full remainder of the line)

    Returns: (next_line_index, primary_keyword, element_name, initial_value).
    Missing fields are returned as Python None.
    """
    lineCount = len(LinesToProcess)

    while lineIndex < lineCount:
        # Remove inline comments and surrounding whitespace.
        line = LinesToProcess[lineIndex].partition("#")[0].strip()
        lineIndex += 1

        # Skip blank/comment-only lines.
        if not line:
            continue

        # Keep only three logical fields; field 3 preserves spaces.
        fields = line.split(maxsplit=2)
        fields += [None] * (3 - len(fields))
        primaryKeyword, elementName, initialValue = fields
        return (lineIndex, primaryKeyword, elementName, initialValue)

    return (lineIndex, None, None, None)


def verifyAllPrimaryKeywordsAreValid():
    """(Pass A) Ensure every primary keyword is one of the known .dd vocabulary."""

    validKeywords = {
        "defineTable",
        "endTable",
        "defineColumn",
        "defineIndex",
        "defineUnary",
        "defineList",
        "defineDict",
    }
    keywordsRequiringElementName = validKeywords - {"endTable"}

    lineIndex = 0

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        if primaryKeyword not in validKeywords:
            print(
                f"{codeLine()}Keyword '{primaryKeyword}' not in vocabulary at line {lineIndex} of the input file"
            )
            exit(1)

        # Basic shape validation before keyword-specific checks.
        if (primaryKeyword in keywordsRequiringElementName) and (elementName is None):
            print(
                f"{codeLine()}Keyword '{primaryKeyword}' missing required element name at line {lineIndex} of the input file"
            )
            exit(1)

        if (primaryKeyword == "defineTable") and ("_" in elementName):
            print(
                f"{codeLine()}A 'defineTable' was found with underscores in the table name at line {lineIndex} of the input file"
            )
            exit(1)

        # Look for 2 or more concatenated underscores in element name
        if (primaryKeyword in ("defineColumn", "defineIndex")) and ("__" in elementName):
            print(
                f"{codeLine()}Concatenated underscores at line {lineIndex} of the input file"
            )
            exit(1)

    return


def verifyBeginEndInnerConsistency():
    """(Pass B) Ensure defineTable/endTable are balanced and column/index appear only inside a table."""

    global AllTableNames

    # Keep pass behavior deterministic if this validator is ever re-run.
    AllTableNames = []

    lineIndex = 0

    currentTableName = None

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        # -# Check defineTable / endTable match up correctly
        if primaryKeyword == "defineTable":
            # If out of sequence
            if currentTableName is not None:
                print(
                    f"{codeLine()}A 'defineTable' was found before the previous table definition ended at line {lineIndex} of the input file"
                )
                exit(1)

            # Set up to handle a new table definition
            currentTableName = elementName
            AllTableNames.append(currentTableName)

        elif primaryKeyword == "endTable":
            if currentTableName is None:
                print(
                    f"{codeLine()}An 'endTable' was found before a matching 'defineTable' at line {lineIndex} of the input file"
                )
                exit(1)
            # Wipe out current table definition
            currentTableName = None

        # -# Check defineColumn / defineIndex are indeed inner
        elif primaryKeyword in ("defineColumn", "defineIndex"):
            if currentTableName is None:
                print(
                    f"{codeLine()}Inner keywords found before 'defineTable' at line {lineIndex} of the input file"
                )
                exit(1)

            if not elementName.startswith(f"{currentTableName}_"):
                print(
                    f"{codeLine()}Inner keywords do not start with current table name at line {lineIndex} of the input file"
                )
                exit(1)

        # -# Check unary keywords are not inner
        elif primaryKeyword in ("defineList", "defineDict", "defineUnary"):
            if currentTableName is not None:
                print(
                    f"{codeLine()}An invalid keyword was found inside the table definition at line {lineIndex} of the input file"
                )
                exit(1)

    if currentTableName is not None:
        print(
            f"{codeLine()}An 'endTable' was missing at line {lineIndex} of the input file"
        )
        exit(1)

    return


def verifyNoDuplicateElementNames():
    """(Pass C) Ensure element names are unique and have no leading/trailing underscores."""

    lineIndex = 0

    uniqueElementNames = set()

    # -# Verify element names are unique
    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        # Only endTable has no element name.
        if primaryKeyword == "endTable":
            continue

        if elementName in uniqueElementNames:
            print(
                f"{codeLine()}Duplicate element name '{elementName}' defined at line {lineIndex} of the input file"
            )
            exit(1)

        if elementName.startswith("_") or elementName.endswith("_"):
            print(
                f"{codeLine()}Leading or trailing underscores are not allowed at line {lineIndex} of the input file"
            )
            exit(1)

        uniqueElementNames.add(elementName)

    return


def verifyLeadingTableNames():
    """(Pass J) Ensure column/index names inside a table start with that table's name."""

    lineIndex = 0

    currentTableName = None

    # -# Verify inner element names lead with table names
    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        if primaryKeyword == "defineTable":

            currentTableName = elementName

        elif primaryKeyword == "endTable":

            currentTableName = None

        elif primaryKeyword in ("defineColumn", "defineIndex"):

            if currentTableName is None or not elementName.startswith(
                f"{currentTableName}_"
            ):
                print(
                    f"{codeLine()}Inner name does not start with table name at line {lineIndex} of the input file"
                )
                exit(1)

    return


def verifyRefColumns():
    """(Pass D) Ensure _Ref columns reference an existing table and not the current table."""

    global AllTableNames

    # -# Verify a ref column cites a valid table other than the current one
    currentTableName = None

    lineIndex = 0

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        # -# Get the current table name
        if primaryKeyword == "defineTable":
            currentTableName = elementName
            continue
        elif primaryKeyword == "endTable":
            currentTableName = None
            continue

        # -# Verify Ref is not to this table and is some other table
        if primaryKeyword == "defineColumn" and elementName.endswith("_Ref"):
            parts = elementName.split("_", 2)
            if len(parts) != 3:
                print(
                    f"{codeLine()}Reference column '{elementName}' is mis-formatted at line {lineIndex} of the input file"
                )
                exit(1)

            srcTable, destTable, _ = parts
            if destTable == currentTableName:
                print(
                    f"{codeLine()}Reference column cites current table at line {lineIndex} of the input file"
                )
                exit(1)
            if destTable not in AllTableNames:
                print(
                    f"{codeLine()}Reference column refers to a non-existent table at line {lineIndex} of the input file"
                )
                exit(1)

    return


def verifyIndices():
    """(Pass E) Ensure each index refers to an existing column in the same table."""

    # -# Verify an index refers to a column in the current table
    lineIndex = 0
    currentTableColumnNames = []
    currentTableColumnCitations = []

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        # -# For each table start, init local data
        if primaryKeyword == "defineTable":
            currentTableColumnNames = []
            currentTableColumnCitations = []

        # -# Acquire list of non-ref column names for this table
        elif primaryKeyword == "defineColumn":
            # If not a _Ref column
            if elementName.count("_") == 1:
                _, columnName = elementName.split("_", 1)
                currentTableColumnNames.append(columnName)

        # -# Acquire list of index citations for this table
        elif primaryKeyword == "defineIndex":
            if elementName.count("_") != 1:
                print(
                    f"{codeLine()}Index column mis-formatted at line {lineIndex} of the input file"
                )
                exit(1)
            tableName, indexCitation = elementName.split("_", 1)
            if not indexCitation.endswith("2Ref"):
                print(
                    f"{codeLine()}Index specification does not end with '2Ref' at line {lineIndex} of the input file"
                )
                exit(1)
            currentTableColumnCitations.append(indexCitation[:-4])

        # -# At the end of the table check for invalid citations
        elif primaryKeyword == "endTable":
            for columnName in currentTableColumnCitations:
                if columnName not in currentTableColumnNames:
                    print(
                        f"{codeLine()}Index specification '{columnName}' doesn't appear in table definition at line {lineIndex} of the input file"
                    )
                    exit(1)

    return


def verifyRequiredColumnsExist():
    """(Pass F) Ensure every table has a Name column and RowStatus as the last column."""

    lineIndex = 0
    currentTableName = None
    nameSeen = False
    rowStatusLast = False

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        if primaryKeyword == "defineTable":

            currentTableName = elementName
            nameSeen = False
            rowStatusLast = False

        elif primaryKeyword == "defineColumn":

            # Seeing another column means the previous one cannot be last.
            rowStatusLast = False

            if elementName == f"{currentTableName}_Name":
                nameSeen = True

            if elementName == f"{currentTableName}_RowStatus":
                rowStatusLast = True

        elif primaryKeyword == "endTable":

            if not nameSeen:
                print(
                    f"{codeLine()}Table '{currentTableName}' doesn't have a Name column at line {lineIndex} of the input file"
                )
                exit(1)

            if not rowStatusLast:
                print(
                    f"{codeLine()}Table '{currentTableName}' doesn't have a RowStatus column LAST at line {lineIndex} of the input file"
                )
                exit(1)

            currentTableName = None

    return


def verifyNoListDictInit():
    """(Pass H) Ensure defineList and defineDict have no initial value."""

    lineIndex = 0

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, initialValue = getNextLineToProcess(
            lineIndex
        )

        if primaryKeyword is None:
            continue

        if primaryKeyword in ("defineList", "defineDict") and (initialValue is not None):
            print(
                f"{codeLine()}'defineList/Dict' can not have an initial value at line {lineIndex} of the input file"
            )
            exit(1)

    return


def generateAllVariableDefinitions(datastoreNamePrefix):
    """Emit code that defines all global shared lists/dicts; unaries are initialized here."""

    global GeneratedCode

    lineIndex = 0

    # Create start of import file.

    GeneratedCode += f"# To consume this file in a Python program:\n"
    GeneratedCode += f"\n"
    GeneratedCode += f"#     exec (open('{datastoreNamePrefix}.py').read())\n"
    GeneratedCode += f"\n"
    GeneratedCode += f"# Start of gDS include file ...\n"
    GeneratedCode += f"\n"
    GeneratedCode += f"import sys\n"
    GeneratedCode += f"from multiprocessing import Manager\n"
    GeneratedCode += f"import json\n"
    GeneratedCode += f"gDSMgr = Manager()\n"

    # Define all the variables needed. Initialize "defineUnary" ones.
    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, initialValue = getNextLineToProcess(
            lineIndex
        )

        if primaryKeyword is None:
            continue

        if primaryKeyword == "defineTable":
            GeneratedCode += f"\n"
            GeneratedCode += f"#\n"
            GeneratedCode += (
                f"# Define global shared variables for entity {elementName}\n"
            )
            GeneratedCode += f"#\n"

        elif primaryKeyword == "defineColumn":
            GeneratedCode += f"{elementName} = gDSMgr.list()\n"

        elif primaryKeyword == "defineUnary":
            GeneratedCode += f"\n"
            GeneratedCode += f"{elementName} = gDSMgr.list()\n"
            GeneratedCode += f"{elementName}.append({initialValue})\n"

        elif primaryKeyword == "defineIndex":
            GeneratedCode += f"{elementName} = gDSMgr.dict()\n"

        elif primaryKeyword == "defineList":
            GeneratedCode += f"{elementName} = gDSMgr.list()\n"

        elif primaryKeyword == "defineDict":
            GeneratedCode += f"{elementName} = gDSMgr.dict()\n"

        elif primaryKeyword == "endTable":
            pass

    return


def generateRowAddCode():
    """Emit code for each table's AddARow: append columns and update indices."""
    global GeneratedCode

    def addRequiredDummyArgs(tableStartLine):
        """Emit function parameters for columns that have no initial value (caller must supply)."""
        global GeneratedCode
        lineIdx, primaryKeyword = tableStartLine, ""
        while primaryKeyword != "endTable":
            lineIdx, primaryKeyword, elementName, initialValue = getNextLineToProcess(
                lineIdx
            )
            if primaryKeyword == "defineColumn" and initialValue is None:
                _, columnArgName = elementName.split("_", 1)
                GeneratedCode += f"    _{columnArgName},\\\n"
        return

    def addOptionalDummyArgs(tableStartLine):
        """Emit function parameters for columns that have an initial value (defaulted)."""
        global GeneratedCode
        lineIdx, primaryKeyword = tableStartLine, ""
        while primaryKeyword != "endTable":
            lineIdx, primaryKeyword, elementName, initialValue = getNextLineToProcess(
                lineIdx
            )
            if primaryKeyword == "defineColumn" and initialValue is not None:
                _, columnArgName = elementName.split("_", 1)
                GeneratedCode += f"    _{columnArgName} = {initialValue},\\\n"
        return

    def addAllDefineIndexCode(tableStartLine):
        """Emit code that updates index dicts when a new row is added; raises KeyError on duplicate key."""
        global GeneratedCode
        lineIdx, primaryKeyword = tableStartLine, ""
        thisRefEmitted = False
        while primaryKeyword != "endTable":
            lineIdx, primaryKeyword, fqDictName, _ = getNextLineToProcess(lineIdx)
            if primaryKeyword == "defineIndex":

                fqColumnName = fqDictName[:-4]

                # See if to-be-inserted column value is already in dictionary.
                # Emit the 'thisRef' calculation only once per added row, even if
                # multiple indices exist for the table.
                if not thisRefEmitted:
                    GeneratedCode += (
                        f"    thisRef = len({currentTableName}_RowStatus) - 1\n\n"
                    )
                    thisRefEmitted = True
                GeneratedCode += f"    if {fqColumnName}[thisRef] in {fqDictName}:\n"
                GeneratedCode += f"        print('')\n"
                GeneratedCode += f"        raise KeyError('Duplicate key in {fqDictName}; value = ', {fqColumnName}[thisRef])\n"
                GeneratedCode += f"        print('')\n"
                GeneratedCode += f"\n"
                GeneratedCode += (
                    f"    {fqDictName}[{fqColumnName}[thisRef]] = thisRef\n"
                )
                GeneratedCode += f"\n"

        return

    #
    # Main part of initial definition
    #
    lineIndex = 0

    currentTableName = None

    currentTableStartLine = None

    rowStatusColumnName = None

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, initialValue = getNextLineToProcess(
            lineIndex
        )

        if primaryKeyword is None:
            continue

        if primaryKeyword == "defineTable":

            currentTableName = elementName

            # So we can rewind to table start
            currentTableStartLine = lineIndex

            # Generate header
            GeneratedCode += f"\n"
            GeneratedCode += f"#\n"
            GeneratedCode += f"# Add a row to table {elementName}\n"
            GeneratedCode += f"#\n"
            GeneratedCode += f"def {currentTableName}_AddARow(\\\n"

            # Re-scan this table's definition generating required then optional dummy arguments
            addRequiredDummyArgs(currentTableStartLine)
            addOptionalDummyArgs(currentTableStartLine)

            # Close out add-a-row header
            GeneratedCode += f"):\n"

            GeneratedCode += f"\n"

        # Now create each column's append of data based on the defineColumn lines
        elif primaryKeyword == "defineColumn":
            # Pull table name off the front of the column name to make arg names
            dummy, columnArgName = elementName.split("_", 1)
            if columnArgName == "RowStatus":
                rowStatusColumnName = elementName
            GeneratedCode += f"    {elementName}.append(_{columnArgName})\n"

        # Add indices after the rest of the header table has been generated
        elif primaryKeyword == "endTable":

            GeneratedCode += f"\n"

            # Process any 'defineIndex' citations
            addAllDefineIndexCode(currentTableStartLine)

            # Generate return of current table length
            GeneratedCode += f"    return (len({rowStatusColumnName}) - 1)\n"

            currentTableName = None

    return


def generateDeleteTableRowCode():
    """
    Emit code for each table's DeleteRows: iterate rows in reverse and
    delete candidate rows in-place, then rebuild any indices.
    """
    global GeneratedCode

    def deleteColumnsAtRowRef(tableStartLine):
        """Emit code to delete the current rowRef from all column lists."""
        global GeneratedCode
        lineIdx, primaryKeyword = tableStartLine, ""
        while primaryKeyword != "endTable":
            lineIdx, primaryKeyword, elementName, _ = getNextLineToProcess(lineIdx)
            if primaryKeyword == "defineColumn":
                GeneratedCode += f"            del {elementName}[rowRef]\n"
        GeneratedCode += f"\n"
        return

    def clearAndRebuildIndices(tableStartLine, tableNameForLen):
        """
        Emit code to clear all index dicts for this table and
        rebuild them from the current column data.
        """
        global GeneratedCode

        # First clear any indices, if present
        lineIdx, primaryKeyword = tableStartLine, ""
        someIndexSeen = False
        while primaryKeyword != "endTable":
            lineIdx, primaryKeyword, elementName, _ = getNextLineToProcess(lineIdx)
            if primaryKeyword == "defineIndex":
                someIndexSeen = True
                GeneratedCode += f"    {elementName}.clear()\n"

        # If indices were seen, process them
        if someIndexSeen:

            # Rebuild indices from current column values
            GeneratedCode += (
                f"    for rowRef in range(len({tableNameForLen}_RowStatus)):\n"
            )

            lineIdx, primaryKeyword = tableStartLine, ""
            while primaryKeyword != "endTable":
                lineIdx, primaryKeyword, elementName, _ = getNextLineToProcess(lineIdx)
                if primaryKeyword == "defineIndex":
                    tableName, columnName = elementName.split("_", 1)
                    targetColumnName = columnName[:-4]
                    GeneratedCode += (
                        f"        {elementName}[{tableName}_{targetColumnName}[rowRef]] = rowRef\n"
                    )

        GeneratedCode += f"\n"
        return

    lineIndex = 0
    currentTableName = None

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        if primaryKeyword == "defineTable":

            currentTableName = elementName
            currentTableStartLine = lineIndex

            GeneratedCode += f"\n"
            GeneratedCode += f"#\n"
            GeneratedCode += f"# Delete erased rows in table {elementName} per RowStatus or, all rows\n"
            GeneratedCode += f"#\n"
            GeneratedCode += (
                f"def {currentTableName}_DeleteRows(allRows, rowStatusValueToDelete = None):\n"
            )
            GeneratedCode += f"\n"
            GeneratedCode += (
                f"    for rowRef in range(len({currentTableName}_RowStatus) - 1, -1, -1):\n"
            )
            GeneratedCode += f"        if (allRows) or ({currentTableName}_RowStatus[rowRef] == rowStatusValueToDelete):\n"

            # Delete this row from all column lists
            deleteColumnsAtRowRef(currentTableStartLine)

            GeneratedCode += f"        else:\n"
            GeneratedCode += f"            pass\n"
            GeneratedCode += f"\n"

            # After all deletions, rebuild any indices that exist
            clearAndRebuildIndices(currentTableStartLine, currentTableName)

            GeneratedCode += (
                f"    return (len({currentTableName}_RowStatus))\n"
            )

    return


def generateTableDumpCode():
    """Emit a DumpRows function per table to print row data (for debugging)."""

    global GeneratedCode

    lineIndex = 0
    currentTableName = None

    while lineIndex < len(LinesToProcess):

        lineIndex, primaryKeyword, elementName, arg1 = getNextLineToProcess(lineIndex)

        if primaryKeyword is None:
            continue

        if primaryKeyword == "defineTable":

            currentTableName = elementName

            GeneratedCode += f"\n"
            GeneratedCode += f"#\n"
            GeneratedCode += f"# Print values out for table '{currentTableName}'\n"
            GeneratedCode += f"#\n"
            GeneratedCode += f"def {currentTableName}_DumpRows(rangeListToDump = None, outFile = sys.stdout):\n"

            headerGenerated = False
            generatedIndexCode = ""

        elif primaryKeyword == "defineColumn":
            # If dumping the first column of the table generate a header with information about the table
            if not headerGenerated:

                headerGenerated = True

                GeneratedCode += "\n"
                GeneratedCode += f"    print(f'**************', file = outFile)\n"
                GeneratedCode += f"    print(f'**************', file = outFile)\n"
                GeneratedCode += f"    print('    Table %s has %d entries' % ('{currentTableName}', len({currentTableName}_RowStatus)), file = outFile)\n"
                GeneratedCode += f"    print(f'**************', file = outFile)\n"
                GeneratedCode += f"    print(f'**************', file = outFile)\n"
                GeneratedCode += f"    print(f'', file = outFile)\n"
                GeneratedCode += "\n"
                GeneratedCode += (
                    f"    for rowRef in range(0, len({currentTableName}_RowStatus)):\n"
                )
                GeneratedCode += f"        if (rangeListToDump is None) or (rowRef in rangeListToDump):\n"
                GeneratedCode += f"            print('    Row reference = %d' % (rowRef), file = outFile)\n"

            # If an reference to another table
            if elementName.endswith("_Ref"):
                dummy, destTableName, dummy = elementName.split("_", 2)
                GeneratedCode += f"            print('    %30s = %10s  (%30s)' % ('{elementName}', {elementName}[rowRef], {destTableName}_Name[{elementName}[rowRef]]), file = outFile)\n"

            else:
                GeneratedCode += f"            print('    %30s = %10s' % ('{elementName}', {elementName}[rowRef]), file = outFile)\n"

        elif primaryKeyword == "defineIndex":
            fqDictName = elementName
            fqColumnName = fqDictName[:-4]

            generatedIndexCode += f"            if {fqDictName}[{fqColumnName}[rowRef]] != rowRef:\n"

            generatedIndexCode += (
                f"                raise ValueError('Bad index value in {fqDictName}; value = ' + "
                f"str({fqColumnName}[rowRef]))\n"
            )

            generatedIndexCode += f"            else:\n"
            generatedIndexCode += f"                print(f\"                    Good index value in {fqDictName}[{{{fqColumnName}[rowRef]!r}}]: {{rowRef}}\", file = outFile)\n"

        elif primaryKeyword == "endTable":
            # Add code that was generated above
            GeneratedCode += generatedIndexCode
            
            GeneratedCode += f"            print('', file = outFile)\n"
            GeneratedCode += "\n"
            GeneratedCode += f"    return\n"
            GeneratedCode += "\n"
            currentTableName = None

    return


def generateTableWriteToFileCode():
    """Emit a WriteToFile function per table: write table rows to a JSON file."""
    global GeneratedCode

    lineIndex = 0
    currentTableName = None

    while lineIndex < len(LinesToProcess):
        lineIndex, primaryKeyword, elementName, _ = getNextLineToProcess(lineIndex)

        if primaryKeyword is not None:
            if primaryKeyword == "defineTable":
                currentTableName = elementName
                GeneratedCode += f"\n"
                GeneratedCode += f"#\n"
                GeneratedCode += (
                    f"# Write table '{currentTableName}' to a JSON file\n"
                )
                GeneratedCode += f"#\n"
                GeneratedCode += (
                    f"def {currentTableName}_WriteToFile(filePath):\n"
                )
                GeneratedCode += f"    rows = []\n"
                GeneratedCode += (
                    f"    for i in range(len({currentTableName}_RowStatus)):\n"
                )
                GeneratedCode += f"        row = {{}}\n"

            elif primaryKeyword == "defineColumn":
                GeneratedCode += (
                    f"        row['{elementName}'] = {elementName}[i]\n"
                )

            elif primaryKeyword == "defineIndex":
                pass

            elif primaryKeyword == "endTable":
                GeneratedCode += f"        rows.append(row)\n"
                GeneratedCode += f"    with open(filePath, 'w') as f:\n"
                GeneratedCode += f"        json.dump(rows, f, indent=2)\n"
                GeneratedCode += f"    return\n"
                GeneratedCode += f"\n"
                currentTableName = None

    return


def generateTableReadFromFileCode():
    """Emit a ReadFromFile function per table: read JSON file and add rows."""
    global GeneratedCode

    lineIndex = 0
    currentTableName = None
    currentTableStartLine = None

    while lineIndex < len(LinesToProcess):
        lineIndex, primaryKeyword, elementName, initialValue = (
            getNextLineToProcess(lineIndex)
        )

        if primaryKeyword is not None:
            if primaryKeyword == "defineTable":
                currentTableName = elementName
                currentTableStartLine = lineIndex
                GeneratedCode += f"\n"
                GeneratedCode += f"#\n"
                GeneratedCode += (
                    f"# Read table '{elementName}' from a JSON file\n"
                )
                GeneratedCode += f"#\n"
                GeneratedCode += f"def {currentTableName}_ReadFromFile(filePath):\n"
                GeneratedCode += f"    with open(filePath) as f:\n"
                GeneratedCode += f"        rows = json.load(f)\n"
                GeneratedCode += f"    for row in rows:\n"
                # Build AddARow call from table columns (required then optional)
                # Required args: columns with no initial value
                argsRequired = []
                argsOptional = []
                lineIdx, pk = currentTableStartLine, ""
                while pk != "endTable":
                    lineIdx, pk, elem, initVal = getNextLineToProcess(lineIdx)
                    if pk == "defineColumn":
                        if initVal is None:
                            argsRequired.append(elem)
                        else:
                            argsOptional.append((elem, initVal))
                argParts = [f"row['{col}']" for col in argsRequired]
                argParts.extend(
                    f"row.get('{col}', {default})"
                    for col, default in argsOptional
                )
                argsStr = ", ".join(argParts)
                GeneratedCode += f"        {currentTableName}_AddARow({argsStr})\n"
                GeneratedCode += f"    return\n"
                GeneratedCode += f"\n"
                currentTableName = None

            elif primaryKeyword in ("defineColumn", "defineIndex", "endTable"):
                pass

    return


