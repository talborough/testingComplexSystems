    _display_table_for_row_ref(dest_table)
    return _prompt_exer_optional(column_label, exer_display, parse_fn)


def _parse_optional_value(text):
    text = text.strip()
    if not text or text.lower() == "none":
        return None
    try:
        return int(text)
    except ValueError:
        return text


def _parse_apply_routine(word):
    """Resolve ApplyRAL menu selection (1-based index or routine name)."""
    word = word.strip().lower()
    idx = _parse_menu_index(word, len(REF_ROUTINES))
    if idx is not None:
        return REF_ROUTINES[idx]
    for spec in REF_ROUTINES:
        if spec[0].lower() == word:
            return spec
    return None


def _inbound_applyral_kinds(dest_table):
    """Return ``{'one'}``, ``{'many'}``, or both for ApplyRAL routines into *dest_table*."""
    kinds = set()
    for _apply_name, _, _owning, dest, many in REF_ROUTINES:
        if dest == dest_table:
            kinds.add("many" if many else "one")
    return kinds


def _has_inbound_applyral(dest_table):
    """True if any ApplyRAL routine targets rows deleted from *dest_table*."""
    return bool(_inbound_applyral_kinds(dest_table))


def _run_deleterows(table):
    """Prompt and call ``{table}_DeleteRows``; return the RAL."""
    delete_fn = DELETE_FNS.get(table)
    if delete_fn is None:
        raise ValueError(f"No DeleteRows routine for {table!r}")
    display_delete_mode_choices(table)
    while True:
        mode = _parse_delete_mode(
            get_terminal_input(
                _menu_choice_prompt(DELETE_MODE_CHOICES),
                normalizer=_normalize_delete_mode_recording,
            )
        )
        if mode in ("allRows", "rowStatusValueToDelete", "rowReferencesToDelete"):
            _commit_script_input()
            break
        print("Enter 1, 2, or 3.", file=sys.stderr)
    if mode == "allRows":
        return delete_fn("allRows")
    if mode == "rowStatusValueToDelete":
        row_status = _parse_optional_value(
            get_terminal_input(
                _default_prompt("RowStatus value to delete", "schema", "None")
            )
        )
        _commit_script_input()
        return delete_fn("rowStatusValueToDelete", row_status)
    if mode == "rowReferencesToDelete":
        _display_table_for_row_ref(table)
        refs_text = get_terminal_input(
            _default_prompt("Row refs to delete", "exer", "none")
        )
        refs = _parse_row_ref_list(refs_text)
        _commit_script_input()
        return delete_fn("rowReferencesToDelete", refs)
    raise ValueError(f"Unknown delete mode {mode!r}")


def _delete_table_rows(table):
    """Delete rows in *table*, save RAL; use apply command to update referencing tables."""
    ral = _run_deleterows(table)
    SAVED_RALS[table] = list(ral)
    _invalidate_apply_ral_completed_for_dest(table)
    deleted = sum(1 for x in ral if x is None)
    kept = len(ral) - deleted
    msg = f"{table}_DeleteRows done: {deleted} row(s) deleted, {kept} kept; RAL saved"
    if _has_inbound_applyral(table):
        seen_apply = set()
        for _apply_name, _, owning, dest, _many in REF_ROUTINES:
            if dest != table:
                continue
            hint = f"use {_apply_name} to update referencing tables"
            if hint in seen_apply:
                continue
            seen_apply.add(hint)
            msg += f"\n{hint}"
    _outcome_summary(msg)


def _get_ral_for_dest(dest_table):
    """Use saved RAL for *dest_table* if requested, else build a new one."""
    if dest_table in SAVED_RALS:
        display_ral_choices(dest_table)
        while True:
            choice = _parse_ral_choice(
                get_terminal_input(
                    _menu_choice_prompt(RAL_CHOICE_CHOICES),
                    normalizer=_normalize_ral_choice_recording,
                )
            )
            if choice in ("saved", "build"):
                _commit_script_input()
                break
            print("Enter 1 (saved) or 2 (build).", file=sys.stderr)
        if choice == "saved":
            _outcome_summary(
                f"Using saved RAL for {dest_table}: {list(SAVED_RALS[dest_table])}"
            )
            return SAVED_RALS[dest_table]
    return _run_deleterows(dest_table)


def _active_script_path():
