def _deref_name(ref, name_col):
    if ref is None:
        return "???"
    try:
        name = name_col[ref]
    except (IndexError, TypeError):
        return "???"
    if name is None:
        return "???"
    return name


def _format_one_ref(label, ref, name_col):
    if ref is None:
        return f"{label}=None(???)"
    name = _deref_name(ref, name_col)
    if name == "???":
        return f"{label}={ref}(???)"
    return f"{label}={name!r}"


def _format_adjust_row_ref(label, ref, name_col):
    """One row ref with dereferenced Name for adjust outcome summaries."""
    if ref is None:
        return f"{label}=None(???)"
    name = _deref_name(ref, name_col)
    if name == "???":
        return f"{label}={ref}(???)"
    return f"{label}={ref} {name!r}"


def _format_many_ref_entry(ref, name_col):
    """One many-ref element: ref index (or None) then dereferenced Name."""
    if ref is None:
        return "None(???)"
    name = _deref_name(ref, name_col)
    if name == "???":
        return f"{ref}(???)"
    return f"{ref} {name!r}"


def _format_many_refs(label, refs, name_col):
    if not refs:
        return f"{label}=[]"
    entries = [_format_many_ref_entry(ref, name_col) for ref in refs]
    return f"{label}=[{', '.join(entries)}]"


def _ref_fields(row, ref_specs):
    parts = []
    for spec in ref_specs:
        label, col, name_col = spec[0], spec[1], spec[2]
        is_many = len(spec) > 3 and spec[3]
        val = col[row]
        if is_many:
            parts.append(_format_many_refs(label, val, name_col))
        else:
            parts.append(_format_one_ref(label, val, name_col))
    return parts


