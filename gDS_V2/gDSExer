def _dispatch_command_line(line):
    """
    Run one main-menu command.

    Returns ``"exit"`` to leave ``exercise_tables``, ``"pause"`` if the user
    should press Return before tables redisplay, or ``"noop"`` otherwise.
    """
    if line is None:
        return "pause"

    stripped = line.strip()
    if not stripped:
        if (
            _SCRIPT is not None
            and _SCRIPT._record_buffer is not None
        ):
            _SCRIPT.discard_record_command_buffer()
        return "noop"

    parts = stripped.split(None, 1)
    cmd = _normalize_command(parts[0].lower())
    arg = parts[1].strip() if len(parts) > 1 else None

    buffered = (
        _SCRIPT is not None
        and (_SCRIPT.is_recording() or cmd == "rec")
    )
    if buffered and _SCRIPT._record_buffer is None:
        _SCRIPT.begin_record_command_buffer()

    def _finish(result, *, commit=False):
        if buffered:
            if commit:
                _SCRIPT.commit_record_command_buffer()
            else:
                _SCRIPT.discard_record_command_buffer()
        return result

    if cmd is not None:
        if (
            _SCRIPT is not None
            and _SCRIPT.is_recording()
            and cmd in ("return", "rec")
        ):
            _discard_script_input()
        else:
            _commit_script_input()
    if cmd is None:
        _print_command_usage()
        return _finish("noop", commit=False)

    if cmd == "rec":
        stack_before = len(_SCRIPT._stack) if _SCRIPT else 0
        _cmd_start_recording(arg)
        commit = _SCRIPT is not None and len(_SCRIPT._stack) > stack_before
        if commit:
            _push_command_history(
                "rec", _command_history_script_name(_SCRIPT.record_path)
            )
        return _finish("pause", commit=commit)

    if cmd == "play":
        stack_before = len(_SCRIPT._stack) if _SCRIPT else 0
        _cmd_start_playback(arg)
        commit = _SCRIPT is not None and len(_SCRIPT._stack) > stack_before
        if commit:
            _push_command_history(
                "play", _command_history_script_name(_SCRIPT.playback_path)
            )
        return _finish("pause", commit=commit)

    if cmd == "return":
        had_stack = _SCRIPT is not None and bool(_SCRIPT._stack)
        returned_path = _cmd_pop_level()
        if had_stack and returned_path:
            _push_command_history(
                "return", _command_history_script_name(returned_path)
            )
        return _finish("pause", commit=had_stack)

    if cmd == "quit":
        return _finish("exit", commit=buffered)

    if cmd == "s/d":
        commit = False
        try:
            from_playback = (
                _SCRIPT is not None and _SCRIPT.last_read_from_playback
            )
            slot = _sd_gold(from_playback=from_playback)
        except (ValueError, OSError) as exc:
            _outcome_summary(exc, file=sys.stderr)
        else:
            commit = True
            _push_command_history("s/d", slot)
        return _finish("pause", commit=commit)

    if cmd == "dump":
        try:
            table = _prompt_table_choice()
        except CommandCancelled:
            return _finish("noop", commit=False)
        if table is None:
            return _finish("pause", commit=False)
        commit = False
        try:
            _dump_table(table)
        except (ValueError, OSError) as exc:
            _outcome_summary(exc, file=sys.stderr)
        else:
            commit = True
            _push_command_history("dump", table)
        return _finish("pause", commit=commit)

    if cmd == "apply":
        display_apply_routines()
        choice = get_terminal_input(
            "ApplyRALTo routine number: ",
            normalizer=_normalize_apply_recording,
        ).strip().lower()
        spec = _parse_apply_routine(choice)
        if spec is None:
            _outcome_summary(f"Unknown ApplyRALTo routine {choice!r}.", file=sys.stderr)
            return _finish("pause", commit=False)
        _commit_script_input()
        commit = False
        try:
            _invoke_apply_ral(spec)
        except CommandCancelled:
            return _finish("noop", commit=False)
        except ValueError as exc:
            _outcome_summary(exc, file=sys.stderr)
        else:
            commit = True
            _push_command_history("apply", spec[2])
        return _finish("pause", commit=commit)

    if cmd == "adjust":
        commit = False
        try:
            adjust_ctx = _invoke_adjust()
        except CommandCancelled:
            return _finish("noop", commit=False)
        except ValueError as exc:
            _outcome_summary(exc, file=sys.stderr)
        else:
            if adjust_ctx is not None:
                commit = True
                table, row_ref = adjust_ctx
                _push_command_history("adjust", table, row_ref)
        return _finish("pause", commit=commit)

    try:
        table = _prompt_table_choice()
    except CommandCancelled:
        return _finish("noop", commit=False)
    if table is None:
        return _finish("noop", commit=False)

    commit = False
    try:
        if cmd == "add":
            row_ref = _create_row(table)
            if row_ref is not None:
                commit = True
                _push_command_history("add", table, row_ref)
        elif cmd == "delete":
            if table not in DELETE_FNS:
                _outcome_summary(f"No DeleteRows routine for {table!r}.", file=sys.stderr)
                return _finish("pause", commit=False)
            _delete_table_rows(table)
            commit = True
            _push_command_history("delete", table)
        elif cmd == "rowstatus":
            row_ref = _set_row_status(table)
            if row_ref is not None:
                commit = True
                _push_command_history("rowstatus", table, row_ref)
    except CommandCancelled:
        return _finish("noop", commit=False)
    except ValueError as exc:
        _outcome_summary(exc, file=sys.stderr)
    return _finish("pause", commit=commit)


def exercise_tables():
    """Interactive menu for exercising gDS tables."""
    _print_defaults_legend_once()
    while True:
        print()
        display_all_tables()
        display_saved_rals()

        _outcome_reset()
        line = _read_main_command_line()
        if line is not None and not line.strip():
            if _SCRIPT is not None:
                _SCRIPT.discard_record_command_buffer()
            continue

        result = _dispatch_command_line(line)
        if result == "exit":
            break
        if result == "pause":
            _outcome_finish()
            _pause_after_command_outcome()


SCRIPT_HELP_EPILOG = """

The exerciser is used to interactively work with (any) schema defined in a .dd file.

First, the .dd file must be compiled with gDSCompile. Then the gDSExer is run with
the same .dd file. The user can then interactively add and delete rows in the tables defined
by the schema and also record exercise/test scripts complete with comparisons against
previously saved gold result files.

The overall flow for recording and playing back script files is:

1) Record sub-scripts that add and delete table rows, and that modify the references between rows.

2) Record a controlling script that plays back the sub-scripts and, at checkpoints, saves the
table state as “gold” files.

3) The controlling script is then played back. At each checkpoint, the newly generated table data
is diffed against the previously saved gold files, producing a PASS or FAIL result.

If a problem occurs during the record phase, the user can resume recording from
where the problem occurred; just remember to play back the previous sub-scripts
before continuing to record.
"""


def _default_py_path(dd_path):
    stem = os.path.splitext(os.path.basename(dd_path))[0]
    return os.path.join(os.path.dirname(os.path.abspath(dd_path)), f"{stem}.py")


def _parse_args():
    parser = argparse.ArgumentParser(
        description="Interactive exerciser/tester for gDS tables from a .dd schema.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=SCRIPT_HELP_EPILOG,
    )
    parser.add_argument(
        "dd",
        metavar="SCHEMA.dd",
        help="gDS schema definition file",
    )
    parser.add_argument(
        "py",
        nargs="?",
        metavar="MODULE.py",
        help="generated Python module (default: <schema-stem>.py beside SCHEMA.dd)",
    )
    return parser.parse_args()


def main():
    global _SCRIPT
    args = _parse_args()
    dd_path = os.path.abspath(args.dd)
    py_path = os.path.abspath(args.py) if args.py else _default_py_path(dd_path)

    try:
        ctx = load_exer_context(dd_path, py_path)
    except (OSError, ValueError, ImportError, RuntimeError) as exc:
        print(exc, file=sys.stderr)
        return 1

    _bind_context(ctx)

    _SCRIPT = ScriptIO()
    try:
        exercise_tables()
    except EOFError as exc:
        print(exc, file=sys.stderr)
        return 1
    finally:
        if _SCRIPT is not None:
            _SCRIPT.close()
            _SCRIPT = None
    return 0


if __name__ == "__main__":
    sys.exit(main())
