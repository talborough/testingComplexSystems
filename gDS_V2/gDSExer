class _TeeStream:
    """Forward writes to *stream* and mirror them to *on_write* (for session recording)."""

    def __init__(self, stream, on_write):
        self._stream = stream
        self._on_write = on_write

    def write(self, s):
        if not s:
            return 0
        self._stream.write(s)
        self._on_write(s)
        return len(s)

    def flush(self):
        self._stream.flush()

    def __getattr__(self, name):
        return getattr(self._stream, name)


class _ScriptFrame:
    """One nested record or playback level on the script stack."""

    __slots__ = (
        "kind",
        "path",
        "record_file",
        "playback_lines",
        "playback_idx",
        "is_gold_owner",
        "gold_op_counter",
        "record_next_line_no",
    )

    def __init__(
        self,
        kind,
        path,
        *,
        record_file=None,
        playback_lines=None,
        is_gold_owner=False,
    ):
        self.kind = kind
        self.path = path
        self.record_file = record_file
        self.playback_lines = playback_lines or []
        self.playback_idx = 0
        self.is_gold_owner = is_gold_owner
        self.gold_op_counter = 0 if is_gold_owner else None
        self.record_next_line_no = 1


class ScriptIO:
    """Record or playback readable gDSExer input scripts (stacked nesting)."""

    def __init__(self):
        self._stack = []
        self.last_read_from_playback = False
        self._pending_record = None
        self._suppress_output_record = False
        self._record_output_partial = ""
        self._record_tee_installed = False
        self._orig_stdout = None
        self._orig_stderr = None
        self._record_buffer = None
        self._record_buffer_line_count = 0

    def begin_record_command_buffer(self):
        """Hold script lines until ``commit_record_command_buffer``."""
        if self._record_buffer is not None:
            return
        self._record_buffer = []
        self._record_buffer_line_count = 0

    def commit_record_command_buffer(self):
        """Append buffered script lines to the open record file."""
        if self._record_buffer is None:
            return
        self._flush_record_output()
        record = self._record_frame()
        if record is None or record.record_file is None or not self._record_buffer:
            self.discard_record_command_buffer()
            return
        for text in self._record_buffer:
            record.record_file.write(text)
        record.record_file.flush()
        record.record_next_line_no += self._record_buffer_line_count
        self.discard_record_command_buffer()

    def discard_record_command_buffer(self):
        """Drop buffered script lines for a failed or cancelled command."""
        self._record_buffer = None
        self._record_buffer_line_count = 0
        self._pending_record = None
        self._record_output_partial = ""

    def _recording_out_deferred(self):
        """True while recording but no command buffer is open yet."""
        return self._record_frame() is not None and self._record_buffer is None

    def _append_to_record(self, record, text, *, line_count=None):
        """Write *text* to the record file or the active command buffer."""
        if line_count is None:
            line_count = text.count("\n")
        if self._record_buffer is not None:
            self._record_buffer.append(text)
            self._record_buffer_line_count += line_count
            return
        if self._recording_out_deferred():
            return
        if record is None or record.record_file is None:
            return
        record.record_file.write(text)
        record.record_file.flush()
        record.record_next_line_no += line_count

    @staticmethod
    def _load_script(path):
        """Load script answers as ``(text, source_line_no)``; line numbers include blanks."""
        entries = []
        with open(path, encoding="utf-8") as fh:
            for line_no, raw in enumerate(fh, start=1):
                line = raw.strip()
                if not line or line.startswith("#"):
                    continue
                entries.append((line, line_no))
        return entries

    @staticmethod
    def _format_prompt(prompt):
        prompt = prompt.rstrip()
        if prompt.endswith("?"):
            prompt = prompt[:-1].rstrip()
        if not prompt.endswith(": "):
            if prompt.endswith(":"):
                prompt += " "
            else:
                prompt += ": "
        return prompt

    @staticmethod
    def _comment_from_prompt(prompt):
        text = prompt.strip().lstrip("\n")
        if text.endswith(":"):
            text = text[:-1].rstrip()
        if text.endswith("?"):
            text = text[:-1].rstrip()
        return text or "input"

    @staticmethod
    def _is_main_command_prompt(prompt):
        return "Enter a command from the above list" in prompt

    def _write_record_entry(self, record, comment, answer):
        """Append a comment/answer pair (no preceding ``# PROMPT:`` line)."""
        comment_line = f"# {comment}\n"
        answer_line = f"{answer}\n\n"
        line_count = comment_line.count("\n") + answer_line.count("\n")
        self._append_to_record(record, comment_line + answer_line, line_count=line_count)

    def _write_record_answer(self, record, answer):
        """Append one response after a preceding ``# PROMPT:`` line."""
        answer_line = f"{answer}\n\n"
        self._append_to_record(record, answer_line, line_count=answer_line.count("\n"))

    def _write_record_output_line(self, record, line):
        text = f"# OUT: {line}\n"
        self._append_to_record(record, text, line_count=1)

    def _record_prompt_line(self, prompt):
        """Write the prompt text shown to the user (recording only)."""
        record = self._record_frame()
        if record is None or record.record_file is None:
            if self._record_buffer is None:
                return
        line = f"# PROMPT: {prompt.rstrip()}\n"
        self._append_to_record(record, line, line_count=line.count("\n"))

    def record_output(self, text):
        """Mirror terminal output into the open record script as ``# OUT:`` lines."""
        if self._suppress_output_record or not text:
            return
        if self._recording_out_deferred():
            return
        record = self._record_frame()
        if record is None or record.record_file is None:
            return
        self._record_output_partial += text
        while "\n" in self._record_output_partial:
            line, self._record_output_partial = self._record_output_partial.split(
                "\n", 1
            )
            self._write_record_output_line(record, line)
        if self._record_buffer is None:
            record.record_file.flush()

    def _flush_record_output(self):
        if not self._record_output_partial:
            return
        if self._recording_out_deferred():
            self._record_output_partial = ""
            return
        record = self._record_frame()
        if record is None or record.record_file is None:
            self._record_output_partial = ""
            return
        self._write_record_output_line(record, self._record_output_partial)
        self._record_output_partial = ""
        if self._record_buffer is None:
            record.record_file.flush()

    def _install_record_tee(self):
        if self._record_tee_installed or self._record_frame() is None:
            return

        def on_write(chunk):
            self.record_output(chunk)

        self._orig_stdout = sys.stdout
        self._orig_stderr = sys.stderr
        sys.stdout = _TeeStream(sys.stdout, on_write)
        sys.stderr = _TeeStream(sys.stderr, on_write)
        self._record_tee_installed = True

    def _remove_record_tee(self):
        if not self._record_tee_installed:
            return
        self._flush_record_output()
        sys.stdout = self._orig_stdout
        sys.stderr = self._orig_stderr
        self._orig_stdout = None
        self._orig_stderr = None
        self._record_tee_installed = False
        self._record_output_partial = ""

    def session_status_lines(self):
        """``RECORD: …`` / ``PLAYBACK: …`` for active script stack levels."""
        lines = []
        record = self._record_frame()
        if record is not None:
            lines.append(
                f"RECORD: {record.path!r} line {record.record_next_line_no}"
            )
        play = self._play_frame()
        if play is not None:
            lines.append(f"PLAYBACK: {play.path!r}")
        return lines

    def _playback_line_label(self, line_number):
        """Script path and source line for playback echo."""
        play = self._play_frame()
        path = play.path if play else "script"
        return f"PLAYBACK {path!r}:{line_number}"

    def _record_frame(self):
        for frame in reversed(self._stack):
            if frame.kind == "record":
                return frame
        return None

    def _play_frame(self):
        for frame in reversed(self._stack):
            if frame.kind == "play":
                return frame
        return None

    def _gold_frame(self):
        for frame in self._stack:
            if frame.is_gold_owner:
                return frame
        return None

    @property
    def record_path(self):
        frame = self._record_frame()
        return frame.path if frame else None

    @property
    def playback_path(self):
        frame = self._play_frame()
        return frame.path if frame else None

    @property
    def active_script_path(self):
        """Outermost script path (gold owner) for save/diff slot numbering."""
        frame = self._gold_frame()
        return frame.path if frame else None

    def end_playback(self):
        """Pop the innermost playback level."""
        play = self._play_frame()
        if play is None:
            return None
        return self.pop_level()[1]

    def is_recording(self):
        return self._record_frame() is not None

    def begin_playback(self, playback_path):
        """Push a playback level; nest under an active record or playback script."""
        path = self._resolve_script_filespec(playback_path)
        nested = bool(self._stack)
        frame = _ScriptFrame(
            "play",
            path,
            playback_lines=self._load_script(path),
            is_gold_owner=not nested,
        )
        self._stack.append(frame)
        self.last_read_from_playback = False
        return path

    @staticmethod
    def _normalize_script_filespec(filespec):
        """Return a script path with ``.scr`` appended when the filespec omits it."""
        path = filespec.strip()
        if not path:
            raise ValueError("Script path required")
        if not os.path.isabs(path):
            path = os.path.normpath(os.path.join(os.getcwd(), path))
        if not path.endswith(".scr"):
            path += ".scr"
        return path

    @staticmethod
    def _resolve_script_filespec(filespec):
        """Resolve *filespec* to an existing ``.scr`` file."""
        path = ScriptIO._normalize_script_filespec(filespec)
        if not os.path.isfile(path):
            raise ValueError(f"Script file not found: {filespec!r}")
        return path

    def begin_recording(self, record_path):
        """Open *record_path* for script recording (interactive level only).

        Returns ``new``, ``overwrite``, or ``append``; ``None`` if cancelled.
        """
        if self._stack:
            return None
        mode = _prompt_script_record_mode(record_path)
        if mode is None:
            return None
        if mode in ("new", "overwrite"):
            record_file = open(record_path, "w", encoding="utf-8")
            header = "# gDSExer script (prompts, responses, and terminal output)\n\n"
            record_file.write(header)
            next_line_no = header.count("\n") + 1
        else:
            with open(record_path, "rb") as fh:
                data = fh.read()
            with open(record_path, "r", encoding="utf-8") as fh:
                next_line_no = sum(1 for _ in fh) + 1
            record_file = open(record_path, "a", encoding="utf-8")
            if data:
                if not data.endswith(b"\n"):
                    record_file.write("\n")
                    next_line_no += 1
                record_file.write("\n")
                next_line_no += 1
        frame = _ScriptFrame(
            "record",
            record_path,
            record_file=record_file,
            is_gold_owner=True,
        )
        frame.record_next_line_no = next_line_no
        self._stack.append(frame)
        self._install_record_tee()
        return mode

    def pop_level(self):
        """Pop one stack level; return ``(kind, path)`` or ``(None, None)``."""
        if not self._stack:
            return None, None
        frame = self._stack.pop()
        if frame.kind == "record":
            self._remove_record_tee()
        if frame.record_file is not None:
            frame.record_file.close()
        self._pending_record = None
        self.last_read_from_playback = False
        return frame.kind, frame.path

    def _set_pending_record(self, prompt, line, normalizer):
        """Hold one prompt/response until validation commits it to the script."""
        if self._record_frame() is None:
            self._pending_record = None
            return
        if self._is_main_command_prompt(prompt) and not line:
            self._pending_record = None
            return
        self._pending_record = (prompt, line, normalizer)

    def commit_pending_record(self):
        """Write the pending prompt/response to the open record script."""
        if self._pending_record is None or self.last_read_from_playback:
            self._pending_record = None
            return
        record = self._record_frame()
        if (
            self._record_buffer is None
            and (record is None or record.record_file is None)
        ):
            self._pending_record = None
            return
        _prompt, line, normalizer = self._pending_record
        recorded = normalizer(line) if normalizer else line
        if recorded == "":
            recorded = "None"
        self._write_record_answer(record, recorded)
        self._pending_record = None

    def read(self, prompt, normalizer=None):
        prompt = self._format_prompt(prompt)
        self.last_read_from_playback = False
        main_command = self._is_main_command_prompt(prompt)
        recording = self._record_frame() is not None and self._play_frame() is None
        defer_main_record = recording and main_command
        if recording and not defer_main_record:
            self._record_prompt_line(prompt)
        play = self._play_frame()
        if play is not None:
            if play.playback_idx >= len(play.playback_lines):
                if self._is_main_command_prompt(prompt):
                    ended = play.path
                    self.end_playback()
                    if self._play_frame() is not None:
                        return self.read(prompt, normalizer)
                    if not self._stack:
                        print(f"Playback ended ({ended!r}).")
                        print()
                    _print_main_command_prompt_context()
                    self._suppress_output_record = True
                    try:
                        line = input(prompt).strip()
                    finally:
                        self._suppress_output_record = False
                else:
                    prompt_label = self._comment_from_prompt(prompt)
                    raise EOFError(
                        f"Script ended unexpectedly at prompt {prompt_label!r}."
                    )
            else:
                if self._is_main_command_prompt(prompt):
                    _print_main_command_prompt_context()
                line, source_line = play.playback_lines[play.playback_idx]
                play.playback_idx += 1
                self.last_read_from_playback = True
                print(
                    f"{self._playback_line_label(source_line)} "
                    f"{prompt.lstrip()}{line}"
                )
        else:
            self._suppress_output_record = True
            try:
                line = input(prompt).strip()
            finally:
                self._suppress_output_record = False

        if defer_main_record and line.strip():
            self.begin_record_command_buffer()
            self._record_prompt_line(prompt)

        self._set_pending_record(prompt, line, normalizer)
        return line

    def close(self):
        self._remove_record_tee()
        while self._stack:
            frame = self._stack.pop()
            if frame.record_file is not None:
                frame.record_file.close()


def _normalize_command_recording(word):
    return _normalize_command(word) or word


def _recordable_script_filespec(path):
    """Prefer a basename (with ``.scr``) when the script lives in the current directory."""
    path = ScriptIO._normalize_script_filespec(path)
    path = os.path.normpath(os.path.abspath(path))
    if os.path.dirname(path) == os.getcwd():
        return os.path.basename(path)
    return path


def _normalize_script_filespec_recording(word):
    scripts = _list_script_files()
    path = _resolve_script_choice(word, scripts)
    if path:
        return _recordable_script_filespec(path)
    try:
        return _recordable_script_filespec(word)
    except ValueError:
        return word


def _record_script_filespec_line(path, comment):
    """Append a filespec answer after inline ``play`` / ``rec`` during recording."""
    if _SCRIPT is None:
        return
    record = _SCRIPT._record_frame()
    if (
        _SCRIPT._record_buffer is None
        and (record is None or record.record_file is None)
    ):
        return
    _SCRIPT._write_record_entry(record, comment, _recordable_script_filespec(path))


def _normalize_table_recording(word):
    table = _parse_table_name(word)
    return table if table else word


def _normalize_apply_recording(word):
    spec = _parse_apply_routine(word)
    return spec[0] if spec else word


def _normalize_adjust_target_recording(word):
    target = _parse_adjust_target(word)
    return target.col_var if target else word


def _normalize_adjust_many_action_recording(word):
    action = _parse_choice_from_menu(
        word, ADJUST_MANY_ACTION_CHOICES, ADJUST_MANY_ACTION_ALIASES
    )
    return action if action else word


def _normalize_delete_mode_recording(word):
    mode = _parse_delete_mode(word)
    return mode if mode else word


def _normalize_ral_choice_recording(word):
    choice = _parse_ral_choice(word)
    return choice if choice else word


def _normalize_delete_action_recording(word):
    action = _parse_delete_action(word)
    return action if action else word


def _parse_menu_index(word, count):
    """Parse a 1-based menu index; return 0-based index or ``None``."""
    word = word.strip()
    if not word:
        return None
    try:
        idx = int(word) - 1
    except ValueError:
        return None
    if 0 <= idx < count:
        return idx
    return None


def _display_numbered_choices(title, choices):
    _consume_post_command_blank()
    print(title)
    print("")
    for i, (key, detail) in enumerate(choices, start=1):
        print(f"  {i} - {key}  ({detail})")
    print()


def _print_defaults_legend_once():
    global _DEFAULTS_LEGEND_PRINTED
    if not _DEFAULTS_LEGEND_PRINTED:
        print()
        print(_DEFAULT_PROMPT_LEGEND)
        _DEFAULTS_LEGEND_PRINTED = True


def _print_ordinary_containers_notice_once():
    """After .py scan: note when storage uses ordinary [] / {} (-O compile)."""
    if _CTX is not None and _CTX.ordinary_containers:
        print("")
        print(
            "The schema was compiled with -O: it defines ordinary [] and {} structures "
            "(not multiprocessing Manager) structures."
        )


def _format_default_display(value):
    if value is None:
        return "None"
    return repr(value)


def _default_prompt(label, source, default_display):
    """*source* is ``schema`` (.dd / AddARow) or ``exer`` (gDSExer-only)."""
    return f"{label} [{source}: {default_display}]: "


def _mandatory_prompt(label, *, required_by):
    """Required value; *required_by* is ``schema`` (.dd) or ``exer`` (command flow)."""
    return (
        f"{label} [{required_by}: required, exer: {_COMMAND_CANCEL_DISPLAY}]: "
    )


def _menu_choice_prompt(choices, *, exer_default=None):
    """Prompt for a numbered menu; default is *exer_default* or the first entry."""
