def _parse_adjust_target(word):
    """Resolve adjust target menu selection (1-based index or column name)."""
    word = word.strip()
    if not word:
        return None
    idx = _parse_menu_index(word, len(ADJUST_TARGETS))
    if idx is not None:
        return ADJUST_TARGETS[idx]
    lower = word.lower()
    for target in ADJUST_TARGETS:
        if target.col_var.lower() == lower or target.label.lower() == lower:
            return target
    return None


def _apply_adjust_change(target, action, owning_row, dest_row):
    """Apply one change (one-ref) or add/remove (many-ref) directly to a ref column."""
    if target.kind == "ref_one":
        if action == "change":
            target.storage[owning_row] = dest_row
        return
    if target.kind == "ref_many":
        col = target.storage
        if action == "add":
            bucket = col[owning_row]
            if bucket is None:
                if _CTX.ordinary_containers:
                    bucket = []
                else:
                    bucket = _CTX.gDSMgr.list()
                col[owning_row] = bucket
            bucket.append(dest_row)
        elif action == "remove":
            refs = col[owning_row]
            if refs is None:
                return
            for ri in range(len(refs) - 1, -1, -1):
                if refs[ri] == dest_row:
                    del refs[ri]


def _invoke_adjust():
    if not ADJUST_TARGETS:
        _outcome_summary("No ref columns to adjust.", file=sys.stderr)
        return None
    display_adjust_targets()
    choice = get_terminal_input(
        "Adjust target number/name: ",
        normalizer=_normalize_adjust_target_recording,
    ).strip()
    target = _parse_adjust_target(choice)
    if target is None:
        _outcome_summary(f"Unknown adjust target {choice!r}.", file=sys.stderr)
        return None
    _commit_script_input()
    if target.kind == "ref_many":
        _display_numbered_choices("Adjust action:", ADJUST_MANY_ACTION_CHOICES)
        while True:
            action = _parse_choice_from_menu(
                get_terminal_input(
                    _menu_choice_prompt(ADJUST_MANY_ACTION_CHOICES),
                    normalizer=_normalize_adjust_many_action_recording,
                ),
                ADJUST_MANY_ACTION_CHOICES,
                ADJUST_MANY_ACTION_ALIASES,
            )
            if action in ("add", "remove"):
                _commit_script_input()
                break
            _outcome_print("Enter 1 (add) or 2 (remove).", file=sys.stderr)
    else:
        action = "change"
    owning_row = _prompt_row_ref(
        f"{target.owning_table} row ref",
        target.owning_table,
    )
    dest_label = (
        f"{target.dest_table} row ref"
        if target.kind == "ref_many"
        else f"{target.dest_table} row ref (change to)"
    )
    dest_row = _prompt_row_ref(dest_label, target.dest_table)
    _apply_adjust_change(target, action, owning_row, dest_row)
    owning_part = _format_adjust_row_ref(
        "owningRow", owning_row, target.owning_name_col
    )
    dest_part = _format_adjust_row_ref("destRow", dest_row, target.dest_name_col)
    _outcome_summary(f"{target.label}: {action} {owning_part} {dest_part}")
    return target.owning_table, owning_row


def _parse_row_ref(text, *, required=False):
    """Parse one row index; blank / ``None`` -> ``None`` unless *required*."""
    text = text.strip()
    if not text or text.lower() == "none":
        if required:
            raise ValueError("row ref is required")
        return None
    try:
        return int(text)
    except ValueError as exc:
        raise ValueError(f"Invalid row ref {text!r}") from exc


def _parse_ref(text):
    """Parse a one-ref value: empty or ``None`` -> ``None``, else row index."""
    return _parse_row_ref(text, required=False)


def _parse_row_ref_list(text):
    """Parse space-separated row refs; blank / ``None`` / ``[]`` -> ``[]``."""
    text = text.strip()
    if not text or text.lower() in ("none", "[]"):
        return []
    refs = []
    for part in text.split():
        if not part or part.lower() == "none":
            continue
        try:
            refs.append(int(part))
        except ValueError as exc:
            raise ValueError(f"Invalid row ref {part!r}") from exc
    return refs


def _parse_many_refs(text):
    """Parse a many-refs value: empty / none -> empty list, else row indices."""
    parsed = _parse_row_ref_list(text)
    if _CTX.ordinary_containers:
        return parsed
    refs = _CTX.gDSMgr.list()
    for row_ref in parsed:
        refs.append(row_ref)
    return refs


def _prompt_row_ref(label, table, *, required_by="exer", show_table=True):
