def _parse_choice_from_menu(word, choices, aliases):
    """Resolve a numbered menu pick, canonical *key*, or alias."""
    word = word.strip().lower()
    if not word:
        return choices[0][0]
    idx = _parse_menu_index(word, len(choices))
    if idx is not None:
        return choices[idx][0]
    mapped = aliases.get(word)
    if mapped in {key for key, _ in choices}:
        return mapped
    for key, _ in choices:
        if key.lower() == word:
            return key
    return None


