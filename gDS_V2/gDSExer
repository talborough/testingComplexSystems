def get_terminal_input(prompt="\nCommand: ", *, normalizer=None):
    """Read one line from a script or stdin.

    Defaults are labeled ``[schema: …]`` (from the .dd / ``*_AddARow``) or
    ``[exer: …]`` (gDSExer only).  Parsers apply the matching value when the
    line is empty.  While recording, call ``_commit_script_input()`` only after
    the response is accepted as valid; lines are held until the command succeeds.
    """
    if _SCRIPT is not None:
        return _SCRIPT.read(prompt, normalizer)
    prompt = prompt.rstrip()
    if prompt.endswith("?"):
        prompt = prompt[:-1].rstrip()
    if not prompt.endswith(": "):
        if prompt.endswith(":"):
            prompt += " "
        else:
            prompt += ": "
    return input(prompt).strip()


