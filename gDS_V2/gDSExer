class CommandCancelled(Exception):
    """User entered ``!!!`` to abort the current multi-step command."""


def _is_command_cancel(text):
    return text.strip() == _COMMAND_CANCEL


def _raise_if_command_cancel(text):
    if _is_command_cancel(text):
        _discard_script_input()
        raise CommandCancelled()


def _print_command_usage():
