            _raise_if_command_cancel(line)
            value = _parse_row_ref(line, required=True)
            _commit_script_input()
            return value
        except CommandCancelled:
            raise
        except ValueError as exc:
            _outcome_summary(exc, file=sys.stderr)


def _prompt_schema_ref(column_label, parse_fn=_parse_ref, *, normalizer=None):
    """Optional one-ref column; show referenced table rows first."""
    dest_table = REF_COLUMN_DEST_TABLE[column_label]
    _display_table_for_row_ref(dest_table)
    return _prompt_schema_optional(column_label, parse_fn, normalizer=normalizer)


def _prompt_exer_many_refs(column_label, exer_display, parse_fn):
    """Many-refs column; show referenced table rows first."""
