def _next_gold_slot_for_session():
    """Next ``01``, ``02``, … slot for the outermost script (s/d sequence)."""
    if _SCRIPT is None:
        raise ValueError(
            "No script file active (record or playback required for s/d)."
        )
    gold = _SCRIPT._gold_frame()
    if gold is None:
        raise ValueError(
            "No script file active (record or playback required for s/d)."
        )
    gold.gold_op_counter += 1
    return f"{gold.gold_op_counter:02d}"


def _test_dir():
    return "tempTables"


def _table_json_path(folder, table):
    return os.path.join(folder, f"{table}.json")


def _gold_exists(folder):
    if not os.path.isdir(folder):
        return False
    return any(
        os.path.isfile(_table_json_path(folder, table))
        for table in DISPLAY_TABLE_ORDER
    )


def _write_all_tables(folder):
    os.makedirs(folder, exist_ok=True)
    for idx, table in enumerate(DISPLAY_TABLE_ORDER):
        path = _table_json_path(folder, table)
        WRITE_FNS[table](path)
        _outcome_print(f"  {table} -> {path!r}", continued=idx > 0)


def _diff_gold_folder_vs_test(gold_folder, test_folder, slot):
    """Diff JSON table files in *gold_folder* vs *test_folder* for slot *slot*."""
    print()
    _outcome_print(
        f"Compare: diff {test_folder!r} vs. gold slot {slot} in {_gold_root_dir()!r}"
    )
    any_diff = False
    table_line_idx = 0
    for table in DISPLAY_TABLE_ORDER:
        gold_path = _table_json_path(gold_folder, table)
        test_path = _table_json_path(test_folder, table)
        continued = table_line_idx > 0
        if not os.path.isfile(gold_path):
            _outcome_print(
                f"  {table}: MISSING gold file {gold_path!r}",
                file=sys.stderr,
                continued=continued,
            )
            any_diff = True
            table_line_idx += 1
            continue
        if not os.path.isfile(test_path):
            _outcome_print(
                f"  {table}: MISSING test file {test_path!r}",
                file=sys.stderr,
                continued=continued,
            )
            any_diff = True
            table_line_idx += 1
            continue
        with open(gold_path, encoding="utf-8") as fh:
            gold_lines = fh.readlines()
        with open(test_path, encoding="utf-8") as fh:
            test_lines = fh.readlines()
        if gold_lines == test_lines:
            _outcome_print(f"  {table}: OK", continued=continued)
            table_line_idx += 1
            continue
        any_diff = True
        _outcome_print(f"  {table}: DIFF", file=sys.stderr, continued=continued)
        table_line_idx += 1
        for line in difflib.unified_diff(
            gold_lines,
            test_lines,
            fromfile=gold_path,
            tofile=test_path,
        ):
            _outcome_print(line, end="", continued=True)
    if any_diff:
        _outcome_summary("Compare: FAILED", file=sys.stderr)
        return False
    _outcome_summary("Compare: PASSED")
    return True


def _compare_at_slot(slot, *, label="s/d (diff)", missing_gold_msg=None):
    """Write tables to tempTables/ and diff against gold slot *slot*."""
    root = _gold_root_dir()
    test = _test_dir()
    gold_folder = os.path.join(root, slot)
    _outcome_print(f"{label}: writing tables to {test!r}")
    _write_all_tables(test)
    if not _gold_exists(gold_folder):
        msg = missing_gold_msg or (
            f"No gold snapshot in {gold_folder!r}; record s/d (save) first."
        )
        raise ValueError(msg)
    return _diff_gold_folder_vs_test(gold_folder, test, slot)


def _loop_compare_until_pass(slot, *, label="s/d (diff)", missing_gold_msg=None):
    """Re-run compare on *slot* until it passes (pause between failures)."""
    while True:
        if _compare_at_slot(
            slot, label=label, missing_gold_msg=missing_gold_msg
        ):
            return
        _outcome_finish()
        _pause_after_command_outcome()
        _outcome_reset()


def _sd_gold(*, from_playback=False):
    """Save gold while recording; diff vs gold slot when line comes from playback."""
    slot = _next_gold_slot_for_session()
    if from_playback:
        _loop_compare_until_pass(
            slot,
            label="s/d (diff)",
            missing_gold_msg=(
                f"No gold snapshot in {_gold_root_dir()}/{slot!r}; "
                "record s/d (save) first."
            ),
        )
        return slot
    folder = os.path.join(_gold_root_dir(), slot)
    _outcome_print(f"s/d (save): writing all tables to {folder!r}")
    _write_all_tables(folder)
    _outcome_summary(f"s/d (save): done (slot {slot})")
    return slot


