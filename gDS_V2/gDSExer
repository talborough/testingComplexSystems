COMMAND_ALIASES = {
    "a": "add",
    "add": "add",
    "d": "delete",
    "delete": "delete",
    "sr": "rowstatus",
    "rowstatus": "rowstatus",
    "p": "apply",
    "apply": "apply",
    "j": "adjust",
    "adjust": "adjust",
    "s/d": "s/d",
    "u": "dump",
    "dump": "dump",
    "q": "quit",
    "quit": "quit",
    "rec": "rec",
    "play": "play",
    "return": "return",
}


def _normalize_command(word):
    """Map a single-letter or full-word command to a canonical full-word command."""
    return COMMAND_ALIASES.get(word.lower())


def _parse_table_name(word):
    if word in DISPLAY_TABLE_ORDER:
        return word
    try:
        idx = int(word) - 1
    except ValueError:
        return None
    if 0 <= idx < len(DISPLAY_TABLE_ORDER):
        return DISPLAY_TABLE_ORDER[idx]
    return None


def _prompt_addarow_value(param):
    """Prompt for one ``*_AddARow`` argument described by *param*."""
    label = param.column_label
    if param.vtype == "defineManyRefs":
        return _prompt_exer_many_refs(label, "none", _parse_many_refs)
    if param.vtype == "defineRowStatus":
        return _prompt_row_status(label)
    if param.vtype == "defineOneRef":
        if param.schema_default is _SCHEMA_REQUIRED:
            return _prompt_required_ref(label)
        return _prompt_schema_ref(label)
    if param.vtype in ("defineName", "defineColumn"):
        if param.schema_default is _SCHEMA_REQUIRED:
            return _prompt_required(label)
        parse_fn = (
            _parse_optional_string
            if param.vtype == "defineName"
            else _parse_optional_value
        )
        return _prompt_schema_optional(label, parse_fn)
    raise ValueError(f"unsupported AddARow param type {param.vtype!r} for {label!r}")


def _format_addarow_value_part(param, value):
    """One ``heading=value`` fragment for a create-row summary line."""
    heading = param.heading
    if param.vtype == "defineOneRef":
        return _format_one_ref(heading, value, param.dest_name_col)
    if param.vtype == "defineManyRefs":
        return _format_many_refs(heading, value, param.dest_name_col)
    return f"{heading}={value!r}"


def _format_created_row_summary(table, row_ref, params, args):
    """Summary after ``<table>_AddARow`` with labeled column values."""
    parts = [
        _format_addarow_value_part(param, value)
        for param, value in zip(params, args)
    ]
    return f"Created {table} row {row_ref}: " + "  ".join(parts)


def _create_row(table):
    add_fn = ADD_FNS.get(table)
    if add_fn is None:
        _outcome_summary(f"No AddARow routine for {table!r}", file=sys.stderr)
        return
    params = ADDAROW_PARAMS.get(table, [])
    if not params:
        _outcome_summary(f"No AddARow parameters for {table!r}", file=sys.stderr)
        return

    kwargs = {}
    for param in params:
        kwargs[f"_{param.col_var}"] = _prompt_addarow_value(param)

    try:
        row_ref = add_fn(**kwargs)
    except ValueError as exc:
        _outcome_summary(exc, file=sys.stderr)
        return

    args = [kwargs[f"_{param.col_var}"] for param in params]
    _outcome_summary(_format_created_row_summary(table, row_ref, params, args))
    return row_ref


def _start_recording_session(filespec=None):
    """Resolve the record script path and open it for writing."""
    if filespec:
        try:
            path = ScriptIO._normalize_script_filespec(filespec)
        except ValueError as exc:
            _outcome_summary(exc, file=sys.stderr)
            return
    else:
        path = _prompt_record_script()
    if path:
        path = ScriptIO._normalize_script_filespec(path)
    if not path:
        _outcome_summary("Recording not started.")
        return
    mode = _SCRIPT.begin_recording(path)
    if mode:
        if filespec:
            _record_script_filespec_line(path, "Record script name")
        else:
            _commit_script_input()
        if mode == "append":
            _outcome_summary(f"Appending to {path!r}.")
        else:
            _outcome_summary(f"Recording to {path!r}.")
    else:
        _outcome_summary("Recording cancelled.")


def _resume_recording_after_playback():
    """Re-prompt for table state after prerequisite playback."""
    filespec = _rec_pending_filespec()
    if not _prompt_table_state_before_recording(filespec):
        if _REC_PENDING is None:
            _outcome_summary("Recording not started.")
        return
    _start_recording_session(filespec)


def _cmd_start_recording(filespec=None):
    """Start recording to a new ``.scr`` (optional *filespec*)."""
    global _SCRIPT
    if _SCRIPT is None:
        _SCRIPT = ScriptIO()
    if _SCRIPT._stack:
        if _SCRIPT.is_recording():
            _outcome_summary(
                f"Already recording to {_SCRIPT.record_path!r}.",
                file=sys.stderr,
            )
        else:
            _outcome_summary(
                "Recording requires interactive mode (return to top level first).",
                file=sys.stderr,
            )
        return
    if _REC_PENDING is not None and filespec is None:
        filespec = _rec_pending_filespec()
    if not _prompt_table_state_before_recording(filespec):
        if _REC_PENDING is None:
            _outcome_summary("Recording not started.")
        return
    _start_recording_session(filespec)


def _cmd_start_playback(filespec=None):
    """Start playback from a ``.scr`` (optional *filespec*)."""
    global _SCRIPT
    if _SCRIPT is None:
        _SCRIPT = ScriptIO()
    if filespec:
        try:
            path = ScriptIO._resolve_script_filespec(filespec)
        except ValueError as exc:
            _outcome_summary(exc, file=sys.stderr)
            return
    else:
        path = _prompt_playback_script()
    if not path:
        _outcome_summary("Playback not started.")
        return
    path = ScriptIO._normalize_script_filespec(path)
    if _SCRIPT.is_recording():
        if filespec:
            _record_script_filespec_line(path, "Playback script")
        else:
            _commit_script_input()
    try:
        _SCRIPT.begin_playback(path)
    except OSError as exc:
        _outcome_summary(exc, file=sys.stderr)
        return
    _outcome_summary(f"Playing back {path!r}.")


def _cmd_pop_level():
    """Pop one script level (``return``). Return the script path popped, or ``None``."""
    global _SCRIPT
    if _SCRIPT is None or not _SCRIPT._stack:
        _outcome_summary("Not recording or playing back.")
        return None
    kind, path = _SCRIPT.pop_level()
    if kind == "record":
        _outcome_summary(f"Stopped recording ({path!r}).")
    elif kind == "play":
        if _SCRIPT._stack:
            _outcome_summary(f"Returned from playback ({path!r}).")
        else:
            _outcome_summary(f"Stopped playback ({path!r}).")
            if _REC_PENDING is not None:
                _resume_recording_after_playback()
    else:
        _outcome_summary("Not recording or playing back.")
    return path


